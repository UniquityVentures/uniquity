#set page(paper: "a4", margin: (x: 1.4cm, y: 1.2cm))
#set text(font: "Liberation Sans", size: 9pt)
#set par(leading: 0.45em)

#let fmt-num(n) = {
  let v = calc.round(n, digits: 2)
  let s = str(v)
  let parts = s.split(".")
  let whole = parts.at(0)
  let frac = if parts.len() > 1 {
    let f = parts.at(1)
    if f.len() == 1 { "." + f + "0" } else { "." + f }
  } else { ".00" }
  let grouped = {
    let chars = whole.clusters().rev()
    let out = ()
    for (i, c) in chars.enumerate() {
      out = (c,) + out
      if calc.rem(i + 1, 3) == 0 and i + 1 < chars.len() {
        out = (",",) + out
      }
    }
    out.join()
  }
  [#grouped#frac]
}

#let inr(n) = [₹ #fmt-num(n)]

#let fmt-qty(q) = {
  let s = str(calc.round(q, digits: 2))
  if not s.contains(".") { s + ".00" }
  else if s.split(".").at(1).len() == 1 { s + "0" }
  else { s }
}

#let pct(v) = float(str(v).trim("%")) / 100.0
#let line-untaxed(ln) = float(str(ln.qty)) * float(str(ln.rate))
#let line-tax-amt(base, t) = base * pct(t.pct)
#let line-net(ln) = {
  let base = line-untaxed(ln)
  let levied = 0.0
  let wh = 0.0
  for t in ln.taxes {
    let a = line-tax-amt(base, t)
    if t.kind == "withholding" { wh += a } else { levied += a }
  }
  base + levied - wh
}
#let tax-label(ln) = {
  let names = ln.taxes.map(t => t.name)
  if names.len() == 0 { [—] } else { names.join(", ") }
}

#let lines = (
{{range .Lines}}
  (
    desc: [{{.Product.Name}}],
    hsn: "{{.Product.HSNCode}}",
    qty: {{.Quantity.String}},
    rate: {{.Rate.String}},
    taxes: (
{{range .Taxes}}
      (name: "{{.Name}}", pct: {{.Percentage.String}}, kind: "{{.TaxType}}"),
{{end}}
    ),
  ),
{{end}}
)

#let header-taxes = (
{{range .Taxes}}
  (name: "{{.Name}}", pct: {{.Percentage.String}}, kind: "{{.TaxType}}"),
{{end}}
)

#let payments = (
{{range .Payments}}
  (amount: {{.Amount.String}}, date: "{{.Datetime.Format "02/01/2006"}}"),
{{end}}
)

#let untaxed-total = lines.map(line-untaxed).sum()
#let line-tax-ids = {
  let ids = (:)
  for ln in lines {
    for t in ln.taxes { ids.insert(t.name, true) }
  }
  ids
}
#let header-only-taxes = header-taxes.filter(t => t.name not in line-tax-ids)

#let tax-totals = {
  let m = (:)
  let use-line-tax-amounts = header-only-taxes.len() == 0
  for ln in lines {
    let base = line-untaxed(ln)
    if use-line-tax-amounts {
      for t in ln.taxes {
        let k = t.name
        let prev = m.at(k, default: 0.0)
        m.insert(k, prev + line-tax-amt(base, t))
      }
    }
  }
  let base = untaxed-total
  for t in header-only-taxes {
    let k = t.name
    let prev = m.at(k, default: 0.0)
    m.insert(k, prev + line-tax-amt(base, t))
  }
  m
}

#let withholding-total = {
  let s = 0.0
  for (name, amt) in tax-totals {
    let t = lines.at(0).taxes.find(t => t.name == name)
    if t != none and t.kind == "withholding" { s += amt }
  }
  for t in header-only-taxes {
    if t.kind == "withholding" { s += line-tax-amt(untaxed-total, t) }
  }
  s
}

#let levied-total = tax-totals.values().sum() - withholding-total
#let grand-total = untaxed-total + levied-total - withholding-total

#let hsn-groups = {
  let g = (:)
  for ln in lines {
    let key = ln.hsn
    let prev = g.at(key, default: (qty: 0.0, untaxed: 0.0, taxes: (:)))
    let base = line-untaxed(ln)
    let tax-map = prev.taxes
    for t in ln.taxes {
      let k = t.name
      tax-map.insert(k, tax-map.at(k, default: 0.0) + line-tax-amt(base, t))
    }
    g.insert(key, (
      qty: prev.qty + float(str(ln.qty)),
      untaxed: prev.untaxed + base,
      taxes: tax-map,
      pct: if ln.taxes.len() > 0 {
        (ln.taxes.map(t => pct(t.pct)).sum() * 100.0)
      } else { 0.0 },
    ))
  }
  g
}

