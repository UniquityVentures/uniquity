#set page(paper: "a4", margin: (x: 1.4cm, y: 1.2cm))
#set text(size: 9.5pt)
#set par(leading: 0.45em)

#let inr(n) = {
  let v = calc.round(n, digits: 2)
  let s = str(v)
  let parts = s.split(".")
  let whole = parts.at(0)
  let frac = if parts.len() > 1 { "." + parts.at(1) } else { "" }
  let grouped = {
    let chars = whole.clusters().rev()
    let out = ()
    for (i, c) in chars.enumerate() {
      out = (c,) + out
      if calc.rem(i + 1, 3) == 0 and i + 1 < chars.len() {
        out = (",",) + out
      }
    }
    out.join()
  }
  [₹ #grouped#frac]
}

#let pct(v) = float(str(v).trim("%")) / 100.0
#let line-untaxed(ln) = float(str(ln.qty)) * float(str(ln.rate))
#let line-tax-amt(base, t) = base * pct(t.pct)
#let line-net(ln) = {
  let base = line-untaxed(ln)
  let levied = 0.0
  let wh = 0.0
  for t in ln.taxes {
    let a = line-tax-amt(base, t)
    if t.kind == "withholding" { wh += a } else { levied += a }
  }
  base + levied - wh
}
#let tax-label(ln) = {
  let names = ln.taxes.map(t => t.name)
  if names.len() == 0 { [—] } else { names.join(", ") }
}

#let lines = (
{{range .Lines}}
  (
    desc: [{{.Product.Name}}],
    hsn: "{{.Product.HSNCode}}",
    qty: {{.Quantity.String}},
    rate: {{.Rate.String}},
    taxes: (
{{range .Taxes}}
      (name: "{{.Name}}", pct: {{.Percentage.String}}, kind: "{{.TaxType}}"),
{{end}}
    ),
  ),
{{end}}
)

#let header-taxes = (
{{range .Taxes}}
  (name: "{{.Name}}", pct: {{.Percentage.String}}, kind: "{{.TaxType}}"),
{{end}}
)

#let untaxed-total = lines.map(line-untaxed).sum()
#let line-tax-ids = {
  let ids = (:)
  for ln in lines {
    for t in ln.taxes { ids.insert(t.name, true) }
  }
  ids
}
#let header-only-taxes = header-taxes.filter(t => t.name not in line-tax-ids)

#let tax-totals = {
  let m = (:)
  let use-line-tax-amounts = header-only-taxes.len() == 0
  for ln in lines {
    let base = line-untaxed(ln)
    if use-line-tax-amounts {
      for t in ln.taxes {
        let k = t.name
        let prev = m.at(k, default: 0.0)
        m.insert(k, prev + line-tax-amt(base, t))
      }
    }
  }
  let base = untaxed-total
  for t in header-only-taxes {
    let k = t.name
    let prev = m.at(k, default: 0.0)
    m.insert(k, prev + line-tax-amt(base, t))
  }
  m
}

#let withholding-total = {
  let s = 0.0
  for (name, amt) in tax-totals {
    let t = lines.at(0).taxes.find(t => t.name == name)
    if t != none and t.kind == "withholding" { s += amt }
  }
  for t in header-only-taxes {
    if t.kind == "withholding" { s += line-tax-amt(untaxed-total, t) }
  }
  s
}

#let levied-total = tax-totals.values().sum() - withholding-total
#let grand-total = untaxed-total + levied-total - withholding-total

#let hsn-groups = {
  let g = (:)
  for ln in lines {
    let key = ln.hsn
    let prev = g.at(key, default: (qty: 0.0, untaxed: 0.0, taxes: (:)))
    let base = line-untaxed(ln)
    let tax-map = prev.taxes
    for t in ln.taxes {
      let k = t.name
      tax-map.insert(k, tax-map.at(k, default: 0.0) + line-tax-amt(base, t))
    }
    g.insert(key, (
      qty: prev.qty + float(str(ln.qty)),
      untaxed: prev.untaxed + base,
      taxes: tax-map,
      pct: if ln.taxes.len() > 0 {
        (ln.taxes.map(t => pct(t.pct)).sum() * 100.0)
      } else { 0.0 },
    ))
  }
  g
}

#align(right)[
  #text(weight: "bold")[Uniquity Ventures] \
  302, Bonanza Arcade \
  Swami Vivekanand Marg, Mumbai \
  Mumbai Suburban 400053 \
  Maharashtra MH \
  India
]

#v(0.8em)

#align(center)[
  #text(size: 13pt, weight: "bold")[
    Customer Invoices
    {{with .Number}}{{.}}{{else}}Draft #{{.ID}}{{end}}
  ]
]

#v(0.6em)

#grid(
  columns: (1fr, 1fr),
  gutter: 1.2em,
  [
    {{if .Customer.Name}}[*{{.Customer.Name}}*]{{end}}
    {{if .Customer.Address}}{{.Customer.Address}} \{{end}}
    {{if .Customer.GSTIN}}GSTIN: {{.Customer.GSTIN}} \{{end}}
    Place of supply: Maharashtra
  ],
  [
    #table(
      columns: (1fr, 1fr, 1fr, 1fr),
      stroke: none,
      inset: 3pt,
      [*Invoice Date*], [*Due Date*], [*Delivery Date*], [*Reference*],
      [
        {{.Datetime.Format "02/01/2006"}}
      ],
      [
        #{
          let d = datetime(
            year: {{.Datetime.Format "2006"}},
            month: {{.Datetime.Format "1"}},
            day: {{.Datetime.Format "2"}},
          )
          (d + duration(days: 15)).display("[day]/[month repr:numerical]/[year]")
        }
      ],
      [—],
      [
        {{range $i, $ln := .Lines}}{{if eq $i 0}}{{if $ln.Product.Reference}}{{$ln.Product.Reference}}{{end}}{{end}}{{end}}
      ],
    )
  ],
)

#v(0.5em)

#table(
  columns: (2.2fr, 0.7fr, 0.55fr, 0.75fr, 0.9fr, 0.85fr),
  stroke: 0.4pt + gray,
  inset: 5pt,
  align: (left, center, right, right, left, right),
  table.header(
    [*Description*], [*HSN/SAC*], [*Quantity*], [*Unit Price*], [*Taxes*], [*Amount*],
  ),
  ..lines.map(ln => (
    ln.desc,
    ln.hsn,
    str(float(str(ln.qty))),
    inr(float(str(ln.rate))),
    tax-label(ln),
    inr(line-untaxed(ln)),
  )).flatten(),
)

#v(0.4em)

#grid(
  columns: (1.1fr, 0.9fr),
  gutter: 1em,
  [
    Payment terms: 15 Days \
    {{if .Customer.PAN}}PAN: {{.Customer.PAN}} \{{end}}
    Payment Communication: (configure in template) \
    on this account: 122505002480 — ICICI Bank
  ],
  [
    #table(
      columns: (1fr, auto),
      stroke: none,
      align: (left, right),
      inset: 3pt,
      [*Untaxed Amount*], inr(untaxed-total),
      ..tax-totals.pairs().map(((name, amt)) => (
        [*#name*], inr(amt),
      )).flatten(),
      [*Total*], [#text(weight: "bold")[#inr(grand-total)]],
    )
    #v(0.3em)
    #text(size: 8.5pt, style: "italic")[
      Total amount in words: {{invoiceGrandTotalWords .}}
    ]
  ],
)

#v(0.6em)

#text(weight: "bold")[HSN Summary]

#table(
  columns: (0.7fr, 0.55fr, 0.55fr, 1fr, 0.85fr, 0.85fr),
  stroke: 0.4pt + gray,
  inset: 5pt,
  align: (center, right, right, right, right, right),
  table.header(
    [*HSN/SAC*], [*Quantity*], [*Rate %*], [*Taxable Value*], [*SGST*], [*CGST*],
  ),
  ..hsn-groups.pairs().map(((hsn, row)) => {
    let share = if untaxed-total > 0.0 { row.untaxed / untaxed-total } else { 0.0 }
    let sgst = tax-totals.at("SGST", default: 0.0) * share
    let cgst = tax-totals.at("CGST", default: 0.0) * share
    (
      hsn,
      str(calc.round(row.qty, digits: 1)),
      str(calc.round(row.pct, digits: 1)),
      inr(row.untaxed),
      inr(sgst),
      inr(cgst),
    )
  }).flatten(),
)

#v(1fr)

#line(length: 100%, stroke: 0.4pt + gray)

#align(center)[
  #context [
    #text(size: 8.5pt)[
      {{if .Customer.Phone}}T: {{.Customer.Phone}} {{end}}
      GSTIN: 27BODPT0346G1ZY
      #h(1fr)
      Page #counter(page).display() / #counter(page).final().first()
    ]
  ]
]
