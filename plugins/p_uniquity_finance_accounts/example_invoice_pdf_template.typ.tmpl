#v(0.8em)
#grid(
  columns: (1.2fr, 1.2fr, 1.2fr, 2.4fr),
  gutter: 1em,
  [
    #text(weight: "bold", size: 8.5pt, fill: rgb("#4a5568"))[Invoice Date] \
    #v(0.1em)
    {{.Datetime.Format "02/01/2006"}}
  ],
  [
    #text(weight: "bold", size: 8.5pt, fill: rgb("#4a5568"))[Due Date] \
    #v(0.1em)
    #{
      let d = datetime(
        year: {{.Datetime.Format "2006"}},
        month: {{.Datetime.Format "1"}},
        day: {{.Datetime.Format "2"}},
      )
      (d + duration(days: 15)).display("[day]/[month repr:numerical]/[year]")
    }
  ],
  [
    #text(weight: "bold", size: 8.5pt, fill: rgb("#4a5568"))[Delivery Date] \
    #v(0.1em)
    {{with .DeliveryDate}}{{.}}{{else}}20/04/2026{{end}}
  ],
  [
    #text(weight: "bold", size: 8.5pt, fill: rgb("#4a5568"))[Reference] \
    #v(0.1em)
    {{range $i, $ln := .Lines}}{{if eq $i 0}}{{if $ln.Product.Reference}}{{$ln.Product.Reference}}{{end}}{{end}}{{end}}
  ]
)

#v(1em)
#table(
  columns: (2.2fr, 0.7fr, 0.6fr, 0.8fr, 0.8fr, 1fr),
  stroke: (x, y) => if y == 0 { (bottom: 0.8pt + rgb("#cbd5e0")) } else { none },
  fill: (x, y) => if y == 0 { none } else { rgb("#f8fafc") },
  inset: 8pt,
  align: (left, center, right, right, center, right),
  table.header(
    [*Description*], [*HSN/SAC*], [*Quantity*], [*Unit Price*], [*Taxes*], [*Amount*],
  ),
  ..lines.map(ln => (
    ln.desc,
    ln.hsn,
    fmt-qty(ln.qty),
    fmt-num(ln.rate),
    tax-label(ln),
    inr(line-untaxed(ln)),
  )).flatten(),
)

#v(0.8em)
#grid(
  columns: (1.2fr, 1fr),
  gutter: 1.5em,
  [
    #set text(size: 9pt, fill: rgb("#2d3748"))
    Payment Communication: *PONO: P26PIN350126* \
    on this account: *122505002480 - ICICI Bank*
    
    #v(1.5em)
    #image("{{ urlImage "https://uniquity.in/wp-content/uploads/2026/01/signatures.png" }}", width: 4.5cm)
  ],
  [
    #let total-paid = if payments.len() > 0 { payments.map(p => float(str(p.amount))).sum() } else { 0.0 }
    #let amount-due = grand-total - total-paid
    
    #let summary-rows = (
      (label: [Untaxed Amount], val: inr(untaxed-total), bold: false, italic: false),
    )
    #for (name, amt) in tax-totals.pairs() {
      summary-rows.push((label: [#name], val: inr(amt), bold: false, italic: false))
    }
    #summary-rows.push((label: [Total], val: inr(grand-total), bold: true, italic: false))
    #for p in payments {
      summary-rows.push((label: [Paid on #p.date], val: inr(float(str(p.amount))), bold: false, italic: true))
    }
    #summary-rows.push((label: [Amount Due], val: inr(amount-due), bold: true, italic: false))
    
    #table(
      columns: (1.3fr, 1fr),
      stroke: none,
      align: (left, right),
      inset: 5pt,
      fill: (x, y) => if calc.even(y) { rgb("#f4f6f9") } else { none },
      ..summary-rows.enumerate().map(((idx, row)) => (
        if row.bold { text(weight: "bold")[#row.label] } else if row.italic { text(style: "italic")[#row.label] } else { row.label },
        if row.bold { text(weight: "bold")[#row.val] } else if row.italic { text(style: "italic")[#row.val] } else { row.val },
      )).flatten()
    )
    
    #v(0.4em)
    #align(right)[
      #text(size: 8pt, fill: rgb("#4a5568"))[Total amount in words:] \
      #text(size: 8.5pt, style: "italic", weight: "medium")[
        {{invoiceGrandTotalWords .}}
      ]
    ]
  ]
)

#v(1em)
#text(weight: "bold", size: 11pt)[HSN Summary]
#v(0.4em)
#table(
  columns: (1fr, 0.8fr, 0.8fr, 1.2fr, 1.2fr, 1.2fr),
  stroke: (x, y) => if y == 0 { (bottom: 0.8pt + rgb("#cbd5e0")) } else if y == hsn-groups.len() { (bottom: 0.8pt + rgb("#cbd5e0")) } else { none },
  inset: 6pt,
  align: (left, right, right, right, right, right),
  table.header(
    [*HSN/SAC*], [*Quantity*], [*Rate %*], [*Taxable Value*], [*SGST*], [*CGST*],
  ),
  ..hsn-groups.pairs().map(((hsn, row)) => {
    let share = if untaxed-total > 0.0 { row.untaxed / untaxed-total } else { 0.0 }
    let sgst = tax-totals.at("SGST", default: 0.0) * share
    let cgst = tax-totals.at("CGST", default: 0.0) * share
    (
      hsn,
      str(calc.round(row.qty, digits: 1)),
      str(calc.round(row.pct, digits: 1)),
      inr(row.untaxed),
      inr(sgst),
      inr(cgst),
    )
  }).flatten(),
)

